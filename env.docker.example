# Copy to .env.docker and fill in. Used by: docker compose --env-file .env.docker up -d --build

MYSQL_ROOT_PASSWORD=choose-a-strong-db-password
MYSQL_PORT=3306
API_PORT=4000

# Must be 32+ characters each
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters-aaaa
JWT_REFRESH_SECRET=replace-with-different-32-random-characters-bbbb

# Your real frontend URL(s), comma-separated (no trailing slashes)
# Local Next.js:
# CLIENT_ORIGIN=http://localhost:3000
# Vercel production + preview:
# CLIENT_ORIGIN=https://your-app.vercel.app,https://your-app-git-main-yourteam.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# true if browser is on a different site than the API (e.g. Vercel + Docker VPS)
COOKIE_CROSS_SITE=false

# Optional
HUGGINGFACE_API_KEY=
